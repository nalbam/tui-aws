# tui-aws Environment Configuration
# Copy to .env and fill in values as needed.

# AWS Configuration (optional — uses ~/.aws/credentials by default)
# AWS_PROFILE=default
# AWS_REGION=ap-northeast-2

# Notification webhook (optional — used by .claude/hooks/notify.sh)
# NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/...

# Debug logging (optional)
# TUI_AWS_DEBUG=true
# TUI_AWS_LOG=/tmp/tui-aws-debug.log
